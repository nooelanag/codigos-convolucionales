# Python
*.pyc
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Logs - Mantener estructura pero ignorar contenido
logs/*.log
logs/*
!logs/.gitkeep

# Debug y análisis - Ignorar todo el contenido generado
debug/
!debug/.gitkeep
!debug/strace/.gitkeep
!debug/perf/.gitkeep
!debug/dumps/.gitkeep

# Temporales
tmp/
!tmp/.gitkeep
*.tmp
*.temp

# Archivos de sistema
.DS_Store
Thumbs.db

# Core dumps
core
core.*

# Packet captures
*.pcap
*.pcapng

# Strace outputs
*.strace

# Perf outputs
*.perf
perf.data
perf.data.old

# Valgrind
*.valgrind
vgcore.*